<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container-fluid pl-4 pr-2">
      <a id="brand-modal-trigger" class="navbar-brand title" href="{{ site.baseurl }}/">
        <img class="navbar-brand-icon" src="{{ '/assets/img/TeleAi.jpg' | relative_url }}" alt="" aria-hidden="true" />
        {% if site.title == 'blank' %}
          {% if site.first_name %}
            <span class="font-weight-bold">
              {{- site.first_name -}}
            </span>
          {% endif %}
          {% if site.middle_name %}
            {{- site.middle_name -}}
          {% endif %}
          {% if site.last_name %}
            {{- site.last_name -}}
          {% endif %}
        {% else %}
          {{- site.title -}}
        {% endif %}
      </a>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% for page in site.pages %}
            {% if page.permalink == '/' %} {% assign about_title = page.title %} {% endif %}
          {% endfor %}

          <!-- About -->
          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/' | relative_url }}">
              {{- about_title }}
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  {%- if p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- p.title }}
                    {% if page.url contains p.url %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <span class="sr-only">Search</span>
                </span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>

  <div
    id="brand-image-modal"
    class="brand-image-modal"
    aria-hidden="true"
    style="
      --brand-modal-image: url('{{ '/assets/img/TeleAI-涉水具身智能团队_.png' | relative_url }}');
      --rov-box-left: 27.23%;
      --rov-box-top: 23.75%;
      --rov-box-width: 18.01%;
      --rov-box-height: 21.0%;
      --wetplug-box-left: 9.3%;
      --wetplug-box-top: 67.0%;
      --wetplug-box-width: 16.6%;
      --wetplug-box-height: 16.6%;
      --wetplug-top-box-left: 9.3%;
      --wetplug-top-box-top: 50.5%;
      --wetplug-top-box-width: 16.6%;
      --wetplug-top-box-height: 16.2%;
      --uav-box-left: 50.16%;
      --uav-box-top: 78.26%;
      --uav-box-width: 14.61%;
      --uav-box-height: 17.01%;
      --uav-mid-box-left: 64.88%;
      --uav-mid-box-top: 78.26%;
      --uav-mid-box-width: 15.86%;
      --uav-mid-box-height: 17.08%;
      --uav-right-box-left: 80.74%;
      --uav-right-box-top: 78.26%;
      --uav-right-box-width: 15.86%;
      --uav-right-box-height: 17.08%;
      --wetplug-label-left: 13.6%;
      --wetplug-label-top: 86.7%;
      --wetplug-label-width: 14.2%;
      --wetplug-label-height: 5.2%;
    "
  >
    <button type="button" class="brand-image-modal__close" data-brand-modal-close aria-label="Close">×</button>
    <div class="brand-image-modal__stage">
      <img
        class="brand-image-modal__img"
        src="{{ '/assets/img/TeleAI-涉水具身智能团队_.png' | relative_url }}"
        alt=""
        aria-hidden="true"
        draggable="false"
      />
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--rov"
        src="{{ '/assets/mp4/海缆作业.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="深海ROV海缆作业视频"
      ></video>
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--wetplug"
        src="{{ '/assets/mp4/深海湿插拔线缆目标检测跟踪2.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="深海湿插拔线缆目标检测跟踪视频2"
      ></video>
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--wetplug-top"
        src="{{ '/assets/mp4/深海湿插拔线缆目标检测跟踪1.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="深海湿插拔线缆目标检测跟踪视频1"
      ></video>
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--uav"
        src="{{ '/assets/mp4/无人机起飞图1.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="无人机起飞视频"
      ></video>
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--uav-mid"
        src="{{ '/assets/mp4/无人机起飞图2.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="无人机起飞视频2"
      ></video>
      <video
        class="brand-image-modal__overlay-video brand-image-modal__overlay-video--uav-right"
        src="{{ '/assets/mp4/无人机起飞图3.mp4' | relative_url }}"
        muted
        autoplay
        loop
        playsinline
        preload="metadata"
        aria-label="无人机起飞视频3"
      ></video>
      <span class="brand-image-modal__overlay-text brand-image-modal__overlay-text--wetplug-label" aria-label="深海湿插拔线缆目标检测跟踪">
        <span class="brand-image-modal__overlay-text-line">深海湿插拔线缆</span>
        <span class="brand-image-modal__overlay-text-line"
          >目标检测跟踪<span class="brand-image-modal__overlay-text-pad" aria-hidden="true">缆</span></span
        >
      </span>
    </div>
  </div>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
